<?xml version="1.0" encoding="utf-8" ?>
<configuration>

	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
	</startup>

	<connectionStrings>
		<add name="MyConnection"
			 connectionString="Server=localhost\SQLEXPRESS;Database=ecomdb;Integrated Security=true;TrustServerCertificate=true"
			 providerName="System.Data.SqlClient" />
	</connectionStrings>

</configuration>