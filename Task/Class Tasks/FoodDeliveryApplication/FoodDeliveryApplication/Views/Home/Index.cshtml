@model FoodDeliveryApplication.Models.ViewModels.HomeViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<h1>Food Delivery Dashboard</h1>

<hr />

<h2>Categories</h2>

<table class="table table-bordered">
    <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Description</th>
    </tr>

    @foreach (var cat in Model.Categories)
    {
        <tr>
            <td>@cat.Id</td>
            <td>@cat.Name</td>
            <td>@cat.Description</td>
        </tr>
    }

</table>

<hr />

<h2>Available Foods</h2>

<div class="row">

    @foreach (var food in Model.Foods)
    {
        <div class="col-md-4 mb-3">
            <div class="card shadow">

                <div class="card-body">

                    <h5>@food.Name</h5>

                    <p>@food.Description</p>

                    <p>
                        Category: @food.Category?.Name
                    </p>

                    <p>
                        Price: ₹@food.Price
                    </p>

                    <a class="btn btn-primary"
                       href="/Cart/Add/@food.Id">
                        Add to Cart
                    </a>

                </div>

            </div>
        </div>
    }

</div>

<hr />

<h2>Cart Items</h2>

<table class="table table-striped">

    <tr>
        <th>Food</th>
        <th>Price</th>
    </tr>

    @foreach (var cart in Model.CartItems)
    {
        <tr>
            <td>@cart.Food.Name</td>
            <td>₹@cart.Food.Price</td>
        </tr>
    }

</table>

<hr />

<h2>Sales</h2>

<table class="table table-success">

    <tr>
        <th>Food</th>
        <th>Quantity</th>
        <th>Total</th>
    </tr>

    @foreach (var sale in Model.Sales)
    {
        <tr>
            <td>@sale.Food.Name</td>
            <td>@sale.Quantity</td>
            <td>₹@sale.TotalAmount</td>
        </tr>
    }

</table>